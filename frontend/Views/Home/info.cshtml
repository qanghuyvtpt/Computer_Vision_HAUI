@{ ViewData["Title"] = "Kiến Thức Động Vật"; }

<div class="container z1" style="max-width:900px">

    <div class="info-hero">
        <h2>🔬 Kiến thức động vật</h2>
        <p>Tìm hiểu đặc điểm của từng nhóm động vật theo chế độ ăn</p>
    </div>

    <!-- TABS -->
    <div class="diet-tab-bar">
        <button class="diet-tab herb active" id="tab-herb" onclick="switchDiet('herb')">🌿 Ăn cỏ</button>
        <button class="diet-tab carn" id="tab-carn" onclick="switchDiet('carn')">🥩 Ăn thịt</button>
        <button class="diet-tab omni" id="tab-omni" onclick="switchDiet('omni')">🍽️ Tạp ăn</button>
        <button class="diet-tab compare" id="tab-compare" onclick="switchDiet('compare')">⚖️ So sánh</button>
    </div>

    <!-- ĂN CỎ -->
    <div class="info-content active" id="info-herb">
        <div class="feat-grid">
            <div class="feat-card"><div class="feat-icon">🦷</div><div class="feat-title">Răng & Hàm</div><div class="feat-desc">Răng cửa sắc để cắt cỏ, răng hàm phẳng rộng để nghiền. Không có nanh hoặc nanh rất nhỏ.</div></div>
            <div class="feat-card"><div class="feat-icon">🫀</div><div class="feat-title">Hệ tiêu hóa</div><div class="feat-desc">Ruột rất dài (10–20× thân). Nhiều loài có dạ dày nhiều ngăn để lên men cellulose (bò, cừu).</div></div>
            <div class="feat-card"><div class="feat-icon">👁️</div><div class="feat-title">Vị trí mắt</div><div class="feat-desc">Mắt nằm hai bên đầu, góc nhìn rộng ~330°. Phát hiện kẻ thù từ nhiều hướng khi đang ăn.</div></div>
            <div class="feat-card"><div class="feat-icon">🦶</div><div class="feat-title">Chân & Di chuyển</div><div class="feat-desc">Móng guốc cứng hoặc chân chạy tốc độ cao. Thiên về trốn chạy, không có móng vuốt tấn công.</div></div>
            <div class="feat-card"><div class="feat-icon">👥</div><div class="feat-title">Tập tính xã hội</div><div class="feat-desc">Thường sống theo bầy đàn lớn. Chia sẻ tín hiệu cảnh báo nguy hiểm trong đàn.</div></div>
            <div class="feat-card"><div class="feat-icon">🌱</div><div class="feat-title">Nguồn thức ăn</div><div class="feat-desc">Cỏ, lá, cây bụi, vỏ cây, rễ, củ. Một số loài ăn thêm hoa quả và hạt.</div></div>
        </div>
        <div class="wl-card p-3 mb-2">
            <div class="chart-title"><i class="bi bi-collection-fill"></i> Loài tiêu biểu</div>
            <div class="species-chips">
                <span class="sp-chip herb">🐄 Bò</span><span class="sp-chip herb">🐘 Voi</span>
                <span class="sp-chip herb">🦌 Hươu</span><span class="sp-chip herb">🐇 Thỏ</span>
                <span class="sp-chip herb">🐴 Ngựa</span><span class="sp-chip herb">🦒 Hươu cao cổ</span>
                <span class="sp-chip herb">🐃 Trâu</span><span class="sp-chip herb">🐑 Cừu</span>
                <span class="sp-chip herb">🦛 Tê giác</span><span class="sp-chip herb">🐐 Dê</span>
                <span class="sp-chip herb">🦘 Kangaroo</span><span class="sp-chip herb">🐼 Gấu trúc</span>
            </div>
        </div>
    </div>

    <!-- ĂN THỊT -->
    <div class="info-content" id="info-carn">
        <div class="feat-grid">
            <div class="feat-card"><div class="feat-icon">🦷</div><div class="feat-title">Răng & Nanh</div><div class="feat-desc">Nanh dài nhọn để giết con mồi, răng hàm sắc kiểu kéo để xé thịt. Hàm cực khỏe.</div></div>
            <div class="feat-card"><div class="feat-icon">🫀</div><div class="feat-title">Hệ tiêu hóa</div><div class="feat-desc">Ruột ngắn hơn (3–5× thân). Acid dạ dày mạnh, tiêu hóa protein và xương nhanh chóng.</div></div>
            <div class="feat-card"><div class="feat-icon">👁️</div><div class="feat-title">Vị trí mắt</div><div class="feat-desc">Mắt hướng về phía trước, thị giác 3D (binocular). Đánh giá khoảng cách khi rượt đuổi.</div></div>
            <div class="feat-card"><div class="feat-icon">🦶</div><div class="feat-title">Móng vuốt</div><div class="feat-desc">Móng vuốt sắc bén, nhiều loài co rút được (mèo). Bắt giữ và tiêu diệt con mồi.</div></div>
            <div class="feat-card"><div class="feat-icon">🎯</div><div class="feat-title">Chiến thuật săn</div><div class="feat-desc">Phục kích, rượt đuổi hoặc săn theo bầy. Não bộ phát triển cao để lập chiến lược.</div></div>
            <div class="feat-card"><div class="feat-icon">⚡</div><div class="feat-title">Tốc độ & Sức mạnh</div><div class="feat-desc">Cơ thể vạm vỡ, phản xạ nhanh. Báo có thể đạt 110km/h, đại bàng bổ nhào 300km/h.</div></div>
        </div>
        <div class="wl-card p-3 mb-2">
            <div class="chart-title"><i class="bi bi-collection-fill"></i> Loài tiêu biểu</div>
            <div class="species-chips">
                <span class="sp-chip carn">🦁 Sư tử</span><span class="sp-chip carn">🐯 Hổ</span>
                <span class="sp-chip carn">🐺 Sói</span><span class="sp-chip carn">🦅 Đại bàng</span>
                <span class="sp-chip carn">🐆 Báo</span><span class="sp-chip carn">🐊 Cá sấu</span>
                <span class="sp-chip carn">🦈 Cá mập</span><span class="sp-chip carn">🐍 Trăn</span>
                <span class="sp-chip carn">🦉 Cú mèo</span><span class="sp-chip carn">🐬 Cá heo</span>
                <span class="sp-chip carn">🦊 Cáo</span><span class="sp-chip carn">🐅 Báo tuyết</span>
            </div>
        </div>
    </div>

    <!-- TẠP ĂN -->
    <div class="info-content" id="info-omni">
        <div class="feat-grid">
            <div class="feat-card"><div class="feat-icon">🦷</div><div class="feat-title">Răng đa dạng</div><div class="feat-desc">Có cả nanh (để ăn thịt) lẫn răng nghiền (để ăn thực vật). Bộ răng linh hoạt nhất trong 3 nhóm.</div></div>
            <div class="feat-card"><div class="feat-icon">🫀</div><div class="feat-title">Tiêu hóa linh hoạt</div><div class="feat-desc">Hệ tiêu hóa trung bình, xử lý được cả protein lẫn cellulose. Enzyme tiêu hóa đa dạng.</div></div>
            <div class="feat-card"><div class="feat-icon">🧠</div><div class="feat-title">Thông minh cao</div><div class="feat-desc">Khả năng học hỏi và thích nghi rất tốt. Tìm kiếm thức ăn sáng tạo, sử dụng công cụ (gấu, quạ).</div></div>
            <div class="feat-card"><div class="feat-icon">🌍</div><div class="feat-title">Thích nghi rộng</div><div class="feat-desc">Sống được trong nhiều môi trường khác nhau từ rừng nhiệt đới đến vùng cực. Sức sống cao.</div></div>
            <div class="feat-card"><div class="feat-icon">🔄</div><div class="feat-title">Chế độ ăn linh hoạt</div><div class="feat-desc">Thay đổi nguồn thức ăn theo mùa. Mùa hè ăn quả, mùa đông có thể ăn thịt (gấu).</div></div>
            <div class="feat-card"><div class="feat-icon">🛡️</div><div class="feat-title">Khả năng sinh tồn</div><div class="feat-desc">Tỉ lệ sống sót cao hơn do không phụ thuộc vào một nguồn thức ăn duy nhất.</div></div>
        </div>
        <div class="wl-card p-3 mb-2">
            <div class="chart-title"><i class="bi bi-collection-fill"></i> Loài tiêu biểu</div>
            <div class="species-chips">
                <span class="sp-chip omni">🐻 Gấu</span><span class="sp-chip omni">🐷 Lợn rừng</span>
                <span class="sp-chip omni">🦡 Lửng mật</span><span class="sp-chip omni">🐒 Khỉ</span>
                <span class="sp-chip omni">🦝 Gấu mèo</span><span class="sp-chip omni">🐦‍⬛ Quạ</span>
                <span class="sp-chip omni">🐔 Gà</span><span class="sp-chip omni">🐢 Rùa biển</span>
                <span class="sp-chip omni">🦜 Vẹt</span><span class="sp-chip omni">🐿️ Sóc</span>
                <span class="sp-chip omni">🦦 Rái cá</span><span class="sp-chip omni">🤲 Con người</span>
            </div>
        </div>
    </div>

    <!-- SO SÁNH -->
    <div class="info-content" id="info-compare">
        <div class="wl-card mb-3" style="overflow:auto">
            <table class="compare-tbl">
                <thead>
                    <tr>
                        <th>Đặc điểm</th>
                        <th class="herb-th">🌿 Ăn cỏ</th>
                        <th class="carn-th">🥩 Ăn thịt</th>
                        <th class="omni-th">🍽️ Tạp ăn</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Răng nanh</td>
                        <td class="herb-td">Không có / rất nhỏ</td>
                        <td class="carn-td">Dài, sắc nhọn</td>
                        <td class="omni-td">Vừa phải, linh hoạt</td>
                    </tr>
                    <tr>
                        <td>Vị trí mắt</td>
                        <td class="herb-td">Hai bên đầu</td>
                        <td class="carn-td">Hướng về phía trước</td>
                        <td class="omni-td">Trung gian</td>
                    </tr>
                    <tr>
                        <td>Độ dài ruột</td>
                        <td class="herb-td">Rất dài (10–20×)</td>
                        <td class="carn-td">Ngắn (3–5×)</td>
                        <td class="omni-td">Trung bình (6–10×)</td>
                    </tr>
                    <tr>
                        <td>Móng / Vuốt</td>
                        <td class="herb-td">Guốc / không vuốt</td>
                        <td class="carn-td">Vuốt sắc, co rút</td>
                        <td class="omni-td">Đa dạng theo loài</td>
                    </tr>
                    <tr>
                        <td>Tập tính</td>
                        <td class="herb-td">Bầy đàn lớn</td>
                        <td class="carn-td">Đơn độc / bầy nhỏ</td>
                        <td class="omni-td">Linh hoạt</td>
                    </tr>
                    <tr>
                        <td>Chiến lược sống</td>
                        <td class="herb-td">Trốn chạy, ẩn náu</td>
                        <td class="carn-td">Săn đuổi, phục kích</td>
                        <td class="omni-td">Thích nghi, cơ hội</td>
                    </tr>
                    <tr>
                        <td>Tần suất ăn</td>
                        <td class="herb-td">Liên tục cả ngày</td>
                        <td class="carn-td">Không thường xuyên</td>
                        <td class="omni-td">Theo mùa</td>
                    </tr>
                    <tr>
                        <td>Acid dạ dày</td>
                        <td class="herb-td">Yếu — lên men</td>
                        <td class="carn-td">Rất mạnh — pH 1–2</td>
                        <td class="omni-td">Trung bình — pH 2–4</td>
                    </tr>
                    <tr>
                        <td>Ví dụ</td>
                        <td class="herb-td">Bò, voi, hươu</td>
                        <td class="carn-td">Sư tử, hổ, sói</td>
                        <td class="omni-td">Gấu, lợn, quạ</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="text-center mt-4">
        <a asp-action="Index" class="btn-analyze" style="text-decoration:none">
            <i class="bi bi-cpu-fill"></i> Thử phân loại ngay
        </a>
    </div>
</div>
