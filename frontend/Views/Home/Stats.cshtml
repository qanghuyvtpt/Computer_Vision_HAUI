@model btlon.Models.StatsViewModel
@{ ViewData["Title"] = "Thống Kê"; }

@section Styles {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
}

<div class="container z1" style="max-width:900px">

    <div class="page-title mb-1"><i class="bi bi-bar-chart-fill" style="color:var(--herb)"></i> Thống kê</div>
    <div class="page-sub">Tổng quan kết quả phân tích</div>

    <!-- STAT CARDS -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <i class="bi bi-collection-fill stat-icon-bg" style="color:var(--txt2)"></i>
                <div class="stat-num" style="color:var(--txt)">@Model.Total</div>
                <div class="stat-lbl">Tổng phân tích</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card herb text-center">
                <i class="bi bi-flower1 stat-icon-bg" style="color:var(--herb)"></i>
                <div class="stat-num">@Model.Herbivore</div>
                <div class="stat-lbl">🌿 Ăn cỏ (@Model.HerbivorePct%)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card carn text-center">
                <i class="bi bi-lightning-charge-fill stat-icon-bg" style="color:var(--carn)"></i>
                <div class="stat-num">@Model.Carnivore</div>
                <div class="stat-lbl">🥩 Ăn thịt (@Model.CarnivorePct%)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card omni text-center">
                <i class="bi bi-yin-yang stat-icon-bg" style="color:var(--omni)"></i>
                <div class="stat-num">@Model.Omnivore</div>
                <div class="stat-lbl">🍽️ Tạp ăn (@Model.OmnivorePct%)</div>
            </div>
        </div>
    </div>

    @if (Model.Total > 0)
    {
        <!-- CHARTS -->
        <div class="row g-3 mb-4">
            <div class="col-md-5">
                <div class="chart-card h-100">
                    <div class="chart-title"><i class="bi bi-pie-chart-fill"></i> Tỉ lệ loại</div>
                    <canvas id="dietPieChart" height="220"></canvas>
                </div>
            </div>
            <div class="col-md-7">
                <div class="chart-card h-100">
                    <div class="chart-title"><i class="bi bi-bar-chart-fill"></i> Số lần theo loại</div>
                    <canvas id="dietBarChart" height="200"></canvas>
                </div>
            </div>
        </div>

        <!-- AVG CONFIDENCE -->
        <div class="chart-card mb-4">
            <div class="chart-title"><i class="bi bi-speedometer2"></i> Độ tự tin trung bình</div>
            <div class="d-flex align-items-center gap-3">
                <div style="font-size:2.8rem;font-weight:800;color:var(--herb)">@Model.AvgConf<span style="font-size:1.2rem">%</span></div>
                <div>
                    <div class="prob-track" style="width:220px;height:10px">
                        <div class="prob-fill herbivore" data-width="@Model.AvgConf" style="width:0%"></div>
                    </div>
                    <div style="font-size:.75rem;color:var(--txt3);margin-top:.3rem">Trên @Model.Total lần phân tích</div>
                </div>
            </div>
        </div>

        <!-- RECENT -->
        @if (Model.Recent.Any())
        {
            <div class="chart-card">
                <div class="chart-title"><i class="bi bi-clock-history"></i> 5 kết quả gần nhất</div>
                <div class="hist-list">
                    @foreach (var item in Model.Recent)
                    {
                        <div class="hist-item @item.TypeClass">
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img class="hist-thumb" src="@item.ImagePath" alt="" />
                            }
                            else
                            {
                                <div class="hist-icon-fallback">@item.TypeIcon</div>
                            }
                            <div class="hist-meta">
                                <div class="hist-name">@item.PredictedLabel</div>
                                <div class="hist-time">@item.CreatedAt.ToString("HH:mm dd/MM")</div>
                            </div>
                            <span class="hist-badge @item.TypeClass">@item.PredictedLabel</span>
                            <span class="hist-conf @item.TypeClass">@item.ConfidencePercent</span>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="hist-empty">
            <div class="e-icon">📊</div>
            <p>Chưa có dữ liệu thống kê. Hãy phân tích một vài ảnh trước nhé!</p>
            <a asp-action="Index" class="btn-retry mt-2">
                <i class="bi bi-upload"></i> Upload ảnh ngay
            </a>
        </div>
    }

</div>
